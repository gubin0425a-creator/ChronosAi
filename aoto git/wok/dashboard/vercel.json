{
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/index.html",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        }
    ],
    "routes": [
        {
            "src": "/((?!public/.*|assets/.*).*)(\\.[a-zA-Z0-9]+|\\.html)",
            "dest": "/server.js"
        }
    ]
}